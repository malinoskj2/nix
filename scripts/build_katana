#!/usr/bin/env sh
# Build the `katana` host. Usage: ./scripts/build_katana [switch|test|boot]
set -e
cd "$(dirname "$0")/.."
# --impure: users/jesse pulls home.file sources from absolute /home/jesse/env
# paths, which pure evaluation rejects. build_home passes it for the same reason.
sudo nixos-rebuild "${1:-switch}" --impure --flake ".#katana"
